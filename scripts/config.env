#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  📡 STREAM RECORDER — CONFIGURATION v2.1.0                                 ║
# ║  All user-configurable settings in one place.                              ║
# ║  Edit this file to customize the recorder behavior.                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Channel Settings ────────────────────────────────────────────────────────
# YouTube channel to monitor. Use the @handle format.
# This is overridden by the YOUTUBE_CHANNEL_ID secret if set.
DEFAULT_CHANNEL_HANDLE="@ChannelName"

# ─── Recording Settings ──────────────────────────────────────────────────────
# Minimum free disk space (GB) required before recording starts
MIN_DISK_SPACE_GB=3

# Maximum recording attempts per session (each attempt tries all 6 methods)
MAX_RECORD_ATTEMPTS=5

# Keep whole file? true = upload the ENTIRE stream as ONE file (no splitting)
# false = split into 30-min parts (useful for very long streams)
KEEP_WHOLE_FILE=true

# Split threshold (only used if KEEP_WHOLE_FILE=false)
SEGMENT_DURATION_MIN=30

# Minimum file size (KB) to consider a recording successful
# Files smaller than this are treated as corrupted/empty
MIN_FILE_SIZE_KB=100

# Maximum recording duration in seconds (5 hours = 18000 seconds)
MAX_RECORD_DURATION=18000

# ─── Duplicate Detection ─────────────────────────────────────────────────────
# Prevent recording the same stream twice
# Stores the last recorded video ID and skips if it matches
ENABLE_DUPLICATE_CHECK=true

# ─── Timezone Settings ───────────────────────────────────────────────────────
# All displayed times and filenames use this timezone
TIMEZONE="Asia/Karachi"
TZ_OFFSET="+0500"
TZ_NAME="PKT"

# ─── Branding ─────────────────────────────────────────────────────────────────
# Used in Discord notifications and file metadata
RECORDER_NAME="The Muslim Lantern"
RECORDER_VERSION="2.2.0"
BOT_USERNAME="The Muslim Lantern"

# ─── Discord Webhook Routing ─────────────────────────────────────────────────
# You can use DIFFERENT Discord channels for different notification types!
#
# How it works:
#   - DISCORD_WEBHOOK_ALERTS  → Live detected, recording failed (alerts channel)
#   - DISCORD_WEBHOOK_LINKS   → Recording complete with download links (links channel)
#   - DISCORD_WEBHOOK_REPORTS → Weekly summary, link refresh, cookie warnings (reports channel)
#
# If a specific webhook is not set, it falls back to the main DISCORD_WEBHOOK_URL
# So if you only set one webhook, ALL notifications go to the same channel (still works!)

# ─── Discord Embed Colors (Decimal) ──────────────────────────────────────────
# These are decimal representations of hex colors for Discord's API
# Live Detected — Vibrant Red
COLOR_LIVE_DETECTED=15736129        # #F02121
# Recording Complete (all uploads) — Emerald Green
COLOR_COMPLETE_SUCCESS=5763757      # #57F2AD
# Recording Complete (partial uploads) — Amber Yellow
COLOR_COMPLETE_PARTIAL=16761095     # #FFC107
# Recording Complete (all uploads failed) — Danger Red
COLOR_COMPLETE_FAILED=15158332      # #E74C3C
# Recording Failed — Dark Red
COLOR_FAILED=15158332               # #E74C3C
# Weekly Summary — Royal Blue
COLOR_WEEKLY=3447003                # #3498DB
# Links Refreshed — Teal Green
COLOR_REFRESH=5763757               # #57F2AD
# System Alert — Orange
COLOR_ALERT=15105570                # #E67E22
# Cookie Warning — Bright Orange
COLOR_COOKIE_WARN=16744448          # #FF8C00
# Health Check — Purple
COLOR_HEALTH=10181046               # #9B59B6

# ─── Upload Settings ─────────────────────────────────────────────────────────
# Maximum retry attempts per cloud service
GOFILE_MAX_RETRIES=3
PIXELDRAIN_MAX_RETRIES=3
ARCHIVE_MAX_RETRIES=3

# Upload timeout in seconds per file
UPLOAD_TIMEOUT=3600   # 60 minutes (for 10GB+ files)

# ─── Cookie Settings ─────────────────────────────────────────────────────────
# IMPORTANT: Cookies CANNOT be auto-refreshed!
# You must manually update the YOUTUBE_COOKIES secret every 2-4 weeks.
# The system will check if cookies are still working and WARN you via Discord
# when they expire, so you can update them.
#
# Cookie health check: runs before every recording attempt
ENABLE_COOKIE_HEALTH_CHECK=true

# Days before the system starts warning you about old cookies
# (tracked from the last time you updated them)
COOKIE_WARNING_DAYS=14

# ─── WARP Settings ────────────────────────────────────────────────────────────
# Whether to use Cloudflare WARP for IP masking
ENABLE_WARP=true

# Maximum time (seconds) to wait for WARP connection
WARP_CONNECT_TIMEOUT=60

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Random delay range (seconds) between API requests
RATE_LIMIT_MIN=2
RATE_LIMIT_MAX=6

# Delay between recording method attempts (seconds)
METHOD_RETRY_DELAY=5

# ─── Auto-Retry Settings ─────────────────────────────────────────────────────
# Delay (seconds) before auto-retrying the entire workflow on failure
AUTO_RETRY_DELAY=120   # 2 minutes

# Maximum workflow-level retry attempts
MAX_WORKFLOW_RETRIES=5

# ─── Link Refresh Settings ───────────────────────────────────────────────────
# How many bytes to download when "pinging" a link to keep it alive
REFRESH_PING_BYTES=1024

# Timeout for each link check (seconds)
REFRESH_CHECK_TIMEOUT=30

# ─── Video Processing Settings ───────────────────────────────────────────────
# CRF value for re-encoding (lower = better quality, larger file)
# 18 is visually lossless for most content
REENCODE_CRF=18

# Video codec preset for re-encoding (slower = better compression)
REENCODE_PRESET="medium"

# Audio bitrate for re-encoding
REENCODE_AUDIO_BITRATE="192k"

# ─── Thumbnail Settings ──────────────────────────────────────────────────────
# Download and save stream thumbnail with the recording
SAVE_THUMBNAIL=true

# ─── Notification Settings ───────────────────────────────────────────────────
# Whether to send "not live" notifications (false = silent when not live)
NOTIFY_NOT_LIVE=false

# Whether to include system health info in notifications
NOTIFY_HEALTH_INFO=true

# ─── Debug ────────────────────────────────────────────────────────────────────
# Set to true for verbose logging
DEBUG=false
